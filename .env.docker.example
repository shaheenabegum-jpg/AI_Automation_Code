# ── AI Test Automation Platform — Docker Environment Variables ──
# Copy this file to .env.docker and fill in your secrets:
#   cp .env.docker.example .env.docker
#
# NOTE: DATABASE_URL, REDIS_URL, and PLAYWRIGHT_PROJECT_PATH are set
# in docker-compose.yml — do NOT put them here.

# ── LLM Provider ──
# Choose: "anthropic" or "gemini"
LLM_PROVIDER=anthropic

# Anthropic Claude (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
ANTHROPIC_MODEL=claude-opus-4-5

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=AIzaSyDbghpo3U9tyZ1fdfa5vMYWPJzCD-SZ9VM
GEMINI_MODEL=gemini-2.0-flash

# ── GitHub ──
# Personal access token with repo scope
GITHUB_TOKEN=ghp_xxxxx
GITHUB_FRAMEWORK_REPO=RajasekharPlay/AI_Automation_MGA

# ── PostgreSQL ──
# Used by both the postgres container and the backend
POSTGRES_PASSWORD=postgres

# ── Branch & Tests ──
AI_TESTS_BRANCH=ai-playwright-tests
GENERATED_TESTS_DIR=tests/generated

# ── App ──
SECRET_KEY=change-me-to-a-real-secret
